@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web

<Tooltip Title="@Title">
    @if (!string.IsNullOrWhiteSpace(Href))
    {
        <a class="@CssClass"
           href="@Href"
           target="@Target"
           title="@Title"
           aria-label="@Title">
            <MaterialIcon Theme="@MaterialIcon.Themes.Outlined" Kind="@Icon" />
        </a>
    }
    else
    {
        <Button Type="ButtonType.Default"
                Class="@CssClass"
                Disabled="@Disabled"
                OnClick="HandleClickAsync">
            <MaterialIcon Theme="@MaterialIcon.Themes.Outlined" Kind="@Icon" />
            <span class="crud-action-button-label">@Title</span>
        </Button>
    }
</Tooltip>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Icon { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string Target { get; set; } = "_blank";

    [Parameter]
    public bool Danger { get; set; }

    private string CssClass => Danger
        ? "crud-action-button crud-action-button-danger"
        : "crud-action-button";

    private Task HandleClickAsync(MouseEventArgs args)
        => OnClick.InvokeAsync();
}
