@page "/system-health"
@layout MainLayout
@using MyProject.Web.Health
@inject ISystemHealthService SystemHealthService
@inject MyProject.Business.Services.Other.AuthenticationStateHelper AuthenticationStateHelper
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ILogger<SystemHealthPage> Logger

<PageTitle>系統健康監控</PageTitle>

@if (!string.IsNullOrWhiteSpace(roleMessage))
{
    <div class="alert alert-danger" role="alert">
        @roleMessage
    </div>
}
else if (report is null)
{
    <div class="system-health-loading">正在讀取系統健康狀態...</div>
}
else
{
    <div class="system-health-page">
        <section class="system-health-summary @GetLightClass(report.Light)">
            <div class="summary-main">
                <span class="traffic-light @GetLightClass(report.Light)" aria-hidden="true"></span>
                <div>
                    <h1>系統健康監控</h1>
                    <p>最後檢查時間：@report.CheckedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm:ss")</p>
                </div>
            </div>
            <div class="summary-score">
                <strong>@report.Score%</strong>
                <span>@GetStatusText(report.Status)</span>
            </div>
        </section>

        <section class="system-health-section">
            <h2>檢查項目</h2>
            <div class="health-items">
                @foreach (var item in report.Items)
                {
                    <article class="health-item @GetLightClass(item.Light)">
                        <div class="health-item-heading">
                            <span class="traffic-light @GetLightClass(item.Light)" aria-hidden="true"></span>
                            <div>
                                <h3>@item.Name</h3>
                                <span>@item.Category · 權重 @item.Weight</span>
                            </div>
                            <strong>@GetStatusText(item.Status)</strong>
                        </div>
                        <p>@item.Evidence</p>
                        @if (!string.IsNullOrWhiteSpace(item.FailureMessage))
                        {
                            <div class="health-failure">@item.FailureMessage</div>
                        }
                    </article>
                }
            </div>
        </section>

        <section class="system-health-section">
            <div class="log-heading">
                <div>
                    <h2>最後 100 筆日誌紀錄</h2>
                    <p>@report.LogTail.Message</p>
                </div>
                <span class="log-path">@report.LogTail.FilePath</span>
            </div>

            @if (report.LogTail.Lines.Count == 0)
            {
                <div class="empty-log">沒有可顯示的日誌紀錄。</div>
            }
            else
            {
                <pre class="log-tail">@string.Join(Environment.NewLine, report.LogTail.Lines)</pre>
            }
        </section>
    </div>
}

@code {
    private SystemHealthReport? report;
    private string? roleMessage;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Initializing system health page.");

        var checkResult = await AuthenticationStateHelper.Check(AuthStateProvider, NavigationManager);
        if (checkResult != MyProject.Business.Services.Other.AuthenticationCheckResult.Succeeded)
        {
            Logger.LogWarning("System health page initialization stopped because authentication check failed.");
            return;
        }

        if (!AuthenticationStateHelper.CheckIsAdmin())
        {
            roleMessage = "您沒有權限檢視系統健康監控。";
            Logger.LogWarning("System health page denied because current user is not an administrator.");
            return;
        }

        report = await SystemHealthService.GetReportAsync();
    }

    private static string GetLightClass(SystemHealthLight light)
    {
        return light switch
        {
            SystemHealthLight.Green => "light-green",
            SystemHealthLight.Yellow => "light-yellow",
            _ => "light-red"
        };
    }

    private static string GetStatusText(SystemHealthStatus status)
    {
        return status switch
        {
            SystemHealthStatus.Healthy => "正常",
            SystemHealthStatus.Degraded => "警示",
            _ => "異常"
        };
    }
}
