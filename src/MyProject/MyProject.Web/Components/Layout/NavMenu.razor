<div class="top-row navbar-dark">
    <div class="sidebar-brand">
        <div class="sidebar-brand-icon">
            <MaterialIcon Theme="@MaterialIcon.Themes.Outlined" Kind="dashboard_customize" />
        </div>
        <div class="sidebar-brand-text">
            <a class="navbar-brand" href="">MyProject.Web</a>
            <div class="navbar-subtitle">管理後台功能清單</div>
        </div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <div class="sidebar-menu-shell">
        <div class="nav-section-title">功能選單</div>
        @if (MenuItems.Count == 0)
        {
            <div class="nav-item px-3">
                <span class="nav-link nav-link-disabled">尚無可用選單</span>
            </div>
        }
        else
        {
            <Menu Class="sidebar-menu" Mode="MenuMode.Inline" Theme="MenuTheme.Light">
                @for (var index = 0; index < MenuItems.Count; index++)
                {
                    <SidebarMenuNode Item="MenuItems[index]" ItemKey="@($"root-{index}")" ActiveMenuPath="@ActiveMenuPath" RouteVersion="@RouteVersion" />
                }
            </Menu>
        }
    </div>
</div>

