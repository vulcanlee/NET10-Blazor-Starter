@inherits LayoutComponentBase

<div class="page @(isSidebarCollapsed ? "sidebar-collapsed" : string.Empty)">
    <div class="sidebar">
        <NavMenu IsSidebarCollapsed="isSidebarCollapsed" OnSidebarToggle="ToggleSidebar" />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-title">@CurrentPageTitle</div>
            <div class="top-row-status">
                <div class="user-menu @(isUserMenuOpen ? "user-menu-open" : string.Empty)">
                    <button type="button"
                            class="user-menu-trigger"
                            aria-label="使用者操作"
                            aria-expanded="@isUserMenuOpen"
                            @onclick="ToggleUserMenu">
                        <span class="user-menu-icon" aria-hidden="true">
                            <MaterialIcon Theme="@MaterialIcon.Themes.Outlined" Kind="account_circle" />
                        </span>
                        <span class="user-menu-text">
                            <span class="user-menu-name">@CurrentUserDisplayName</span>
                            @if (CurrentUserIsAdmin)
                            {
                                <span class="user-menu-badge">管理員</span>
                            }
                        </span>
                        <span class="user-menu-caret" aria-hidden="true">
                            <MaterialIcon Theme="@MaterialIcon.Themes.Outlined" Kind="expand_more" />
                        </span>
                    </button>

                    <div class="user-menu-dropdown" role="menu" aria-label="使用者操作">
                        <button type="button" class="user-menu-item" role="menuitem" @onclick="OnChangePasswordClick">變更密碼</button>
                        <a class="user-menu-item" href="/Auths/Logout" role="menuitem">登出</a>
                    </div>
                </div>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<Modal Title="變更密碼"
       Class="change-password-modal"
       @bind-Visible="@changePasswordVisible"
       Keyboard="true"
       OnOk="OnChangePasswordOkAsync"
       OnCancel="OnChangePasswordCancelAsync"
       OkText="@("確認變更")"
       CancelText="@("取消")">
    @if (isSupportAccount)
    {
        <AntDesign.Alert Message="系統預設帳號 support 不允許變更密碼。" Type="@AntDesign.AlertType.Warning" ShowIcon="true" />
    }
    else
    {
        <AntDesign.Form TModel="ChangePasswordForm" Model="@changePasswordForm" Layout="FormLayout.Vertical">
            <FormItem Label="目前密碼" Required>
                <InputPassword @bind-Value="changePasswordForm.CurrentPassword" Placeholder="請輸入目前密碼" />
            </FormItem>
            <FormItem Label="新密碼" Required>
                <InputPassword @bind-Value="changePasswordForm.NewPassword" Placeholder="請輸入新密碼（至少 6 個字元）" />
            </FormItem>
            <FormItem Label="確認新密碼" Required>
                <InputPassword @bind-Value="changePasswordForm.ConfirmPassword" Placeholder="請再次輸入新密碼" />
            </FormItem>
            @if (!string.IsNullOrEmpty(changePasswordErrorMessage))
            {
                <AntDesign.Alert Message="@changePasswordErrorMessage" Type="@AntDesign.AlertType.Error" ShowIcon="true" />
            }
        </AntDesign.Form>
    }
</Modal>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">關閉</span>
</div>
